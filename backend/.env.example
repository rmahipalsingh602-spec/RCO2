# RCO2 Environment Variables
# Copy to backend/.env (Render) or project-root .env (local PowerShell helper).

DATABASE_URL=sqlite+aiosqlite:///./rco2.db
# Render/Postgres values like postgres://... are auto-converted to asyncpg.
# POSTGRES_URL=postgresql://username:password@localhost:5432/rco2

SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

BACKEND_URL=http://127.0.0.1:8001
FRONTEND_URL=http://127.0.0.1:5173
FRONTEND_URLS=
FRONTEND_ORIGIN_REGEX=
GOOGLE_REDIRECT_PATH=/auth/google/callback

# Create a Google OAuth 2.0 Web client and paste the real credentials here.
# Authorized JavaScript origin:
#   http://127.0.0.1:5173
# Authorized redirect URI:
#   http://127.0.0.1:8001/auth/google/callback
# Optional compatibility alias also supported by the backend:
#   http://127.0.0.1:8001/auth/callback
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_secret

AUTH_COOKIE_NAME=rco2_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# For Render + Vercel production set roughly:
# BACKEND_URL=https://your-render-service.onrender.com
# FRONTEND_URL=https://your-vercel-project.vercel.app
# FRONTEND_ORIGIN_REGEX=^https://your-vercel-project(-.*)?\\.vercel\\.app$
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAME_SITE=none
